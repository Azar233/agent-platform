# ═══════════════════════════════════════════════════════
# 基于 YOLOv11 的目标检测智能体平台 — 环境变量配置
# ═══════════════════════════════════════════════════════

# ── DashScope Embedding + Chroma ─────────────────────
# 复制为 backend/.env 后填写真实 Key；backend/.env 已被 Git 忽略。
DASHSCOPE_API_KEY=sk-your-dashscope-api-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024
EMBEDDING_BATCH_SIZE=10
CHROMA_PERSIST_DIR=../.runtime/chroma
CHROMA_DISTANCE=cosine
RAG_CHUNK_TOKENS=400
RAG_CHUNK_OVERLAP_TOKENS=60
RAG_TOP_K=5
RAG_MIN_SIMILARITY=0.45
RAG_DEDUP_SIMILARITY=0.88
RAG_ADJACENT_DEDUP_SIMILARITY=0.50
RAG_MAX_CHUNKS_PER_SOURCE=2
RAG_CANDIDATE_MULTIPLIER=4
ROUTER_MIN_SIMILARITY=0.42
# hybrid（默认）保留强意图与工作流保护；embedding_only 仅用于评估向量路由效果。
AGENT_ROUTING_MODE=hybrid
LONG_TERM_MEMORY_TOP_K=3
LONG_TERM_MEMORY_MIN_SIMILARITY=0.55
LONG_TERM_MEMORY_DEDUPE_SIMILARITY=0.90
AGENT_CONTEXT_HISTORY_TOKENS=6000
AGENT_CONTEXT_SUMMARY_TOKENS=1200
AGENT_CONTEXT_RECENT_MESSAGES=12
AGENT_CONTEXT_TOOL_RESULT_CHARS=1600
AGENT_HANDOFF_TTL_SECONDS=86400
AGENT_CONFIRMATION_TTL_SECONDS=600

# ── 数据库配置 ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your-database-name
DB_USER=your-database-username
DB_PASSWORD=your-database-password

# ── Redis 配置 ──────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# DeepSeek Agent (OpenAI-compatible API)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Replace with the exact DeepSeek V4 Flash model id available to your account.
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TEMPERATURE=0.1

# Managed dataset versions and temporary annotation review
TRAIN_OUTPUT_DIR=runs/train
DATASET_BASE_DIR=datasets
DATASET_VERSION_ROOT=dataset_versions
DATASET_STAGING_ROOT=../.runtime/dataset-staging
DATASET_STAGING_TTL_SECONDS=3600
DATASET_OPERATION_TTL_SECONDS=3600
DATASET_MAX_UPLOAD_MB=20
DATASET_MAX_BATCH_SIZE=500
YOLO_CONFIG_DIR=../.runtime/ultralytics

# Detection inference
DETECTION_MODEL_PATH=your-model-path
DETECTION_OUTPUT_DIR=runs/detect
DETECTION_UPLOAD_DIR=../.runtime/uploads
DETECTION_MAX_FILE_MB=20
DETECTION_MAX_BATCH_SIZE=30
DETECTION_VIDEO_MAX_FILE_MB=50
MODEL_IMPORT_MAX_FILE_MB=1024
VIDEO_FRAME_SAMPLE_RATE=5
VIDEO_MAX_KEY_FRAMES=50
VIDEO_TASK_TTL_SECONDS=3600
VIDEO_RESULT_DIR=runs/detect/video-results
VIDEO_TRACKING_ENABLED=true
VIDEO_TRACKING_MAX_SECONDS=120
VIDEO_TRACK_FRAME_STRIDE=2
MEDIA_ROOT=../.runtime/media
USER_AVATAR_MAX_FILE_MB=2
IP_WEBCAM_URL=http://10.172.52.70:8080
CAMERA_CONFIDENCE=0.30
CAMERA_IOU=0.45
CAMERA_IMAGE_SIZE=512
CAMERA_TARGET_FPS=3
CAMERA_JPEG_QUALITY=62
CAMERA_OUTPUT_MAX_WIDTH=960
CAMERA_READ_TIMEOUT_MS=2000
CAMERA_STALE_TIMEOUT_SECONDS=5
CAMERA_STABILITY_MIN_HITS=2
CAMERA_STABILITY_MAX_MISSES=2
CAMERA_STABILITY_IOU=0.25
# ── MinIO 对象存储配置 ───────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET=rsod-images
MINIO_SECURE=false

# ── JWT 认证配置 ─────────────────────────────────────
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
MOCK_PAYMENT_EXPIRE_MINUTES=10

# ── 应用配置 ─────────────────────────────────────────
APP_NAME=RSOD Agent Platform
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=INFO
LOG_DIR=../.runtime/backend-logs
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
SQL_ECHO=false

# ── CORS 配置 ────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080
