{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "build": "vite build",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{vue,js,scss}\" \"tests/**/*.{vue,js}\" \"*.js\"",
    "format:check": "prettier --check \"src/**/*.{vue,js,scss}\" \"tests/**/*.{vue,js}\" \"*.js\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "axios": "^1.18.1",
    "echarts": "^5.6.0",
    "element-plus": "^2.14.2",
    "gsap": "^3.15.0",
    "lenis": "^1.3.25",
    "markdown-it": "^14.3.0",
    "pinia": "^3.0.4",
    "qrcode": "^1.5.4",
    "vue": "^3.5.39",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "happy-dom": "^20.10.6",
    "prettier": "3.9.5",
    "sass": "^1.101.0",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
